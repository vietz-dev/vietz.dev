---
import Layout from "../layouts/Layout.astro";
import Moin from "../components/Moin.astro";

const facts = [
  { label: "location", value: "Münster, DE" },
  { label: "focus", value: "Full-Stack" },
  { label: "employer", value: "Atruvia AG" },
];
---

<Layout>
  <section class="site-container page-section home-page">
    <Moin />

    <div class="home-divider"></div>

    <section class="home-intro">
      <p class="home-lead">
        Moin! I am <strong>Justin Vietz</strong>, a full-stack developer by ❤️
      </p>

      <div class="home-copy">
        <p>
          I build things for the web — from frontend interfaces that feel right, to backend systems that stay out of the way.
          Currently based in <strong>Münster, Germany</strong>, I work on products where good engineering and clear thinking go hand in hand.
        </p>
        <p>
          Full stack, end to end — TypeScript, Go, React, Angular, Svelte, and whatever infrastructure it takes to ship and keep it running.
          The framework is a means to an end. What I actually care about is maintainable code, reproducible infrastructure, and staying curious.
        </p>
        <p>
          On this site you'll find my <a class="text-link" href="/projects">projects</a> and a
          <a class="text-link" href="/blog">blog</a> where I write about what I'm building and thinking about.
        </p>
      </div>
    </section>

    <section class="facts-grid" aria-label="Quick facts">
      {
        facts.map((fact) => (
          <div class="fact-item">
            <div class="fact-label">{fact.label}</div>
            <div class="fact-value">{fact.value}</div>
          </div>
        ))
      }
    </section>
  </section>
</Layout>

<style>
  .home-page {
    padding-top: 64px;
  }

  .home-divider {
    border-top: 1px solid var(--border);
    margin-bottom: 48px;
  }

  .home-intro {
    margin-bottom: 56px;
  }

  .home-lead {
    margin: 0 0 24px;
    font-family: "IBM Plex Mono", monospace;
    font-size: clamp(18px, 2.5vw, 22px);
    line-height: 1.65;
    color: var(--fg);
    font-weight: 300;
  }

  .home-lead strong,
  .home-copy strong {
    color: var(--fg);
    font-weight: 700;
  }

  .home-copy {
    display: grid;
    gap: 16px;
  }

  .home-copy p {
    margin: 0;
    font-size: 15px;
    line-height: 1.75;
    color: var(--fg-muted);
  }

  .facts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1px;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--border);
  }

  .fact-item {
    background: var(--bg-card);
    padding: 18px 22px;
  }

  .fact-label {
    margin-bottom: 6px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-faint);
  }

  .fact-value {
    font-size: 14px;
    font-weight: 500;
    color: var(--fg);
  }
</style>
