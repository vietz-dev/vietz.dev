---
import Linkedin from "@lucide/astro/icons/linkedin";
import Github from "simple-icons-astro/Github";
import Xing from "simple-icons-astro/Xing";

type SocialLink = {
  Icon: typeof Github | typeof Linkedin;
  text: string;
  href: string;
};

const socialLinks: SocialLink[] = [
  {
    Icon: Github,
    text: "GitHub",
    href: "https://github.com/vietz-dev",
  },
  {
    Icon: Linkedin,
    text: "LinkedIn",
    href: "https://www.linkedin.com/in/justin-vietz",
  },
  {
    Icon: Xing,
    text: "Xing",
    href: "https://www.xing.com/profile/Justin_Vietz",
  },
];
---

<footer class="site-footer">
  <div class="site-container footer-inner">
    <ul class="footer-links">
      {
        socialLinks.map(({ Icon, text, href }) => (
          <li>
            <a class="footer-link" href={href} target="_blank" rel="noopener noreferrer">
              <Icon size={16} />
              <span>{text}</span>
            </a>
          </li>
        ))
      }
    </ul>
    <p class="footer-copy">© 2026 Justin Vietz. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    padding-top: 32px;
    padding-bottom: 40px;
    border-top: 1px solid var(--border);
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 0;
    margin: 0 0 32px;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: fit-content;
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-size: 14px;
    transition: color 0.15s ease;
  }

  .footer-link:hover {
    color: var(--accent);
  }

  .footer-copy {
    margin: 0;
    font-size: 13px;
    color: var(--fg-faint);
  }
</style>
