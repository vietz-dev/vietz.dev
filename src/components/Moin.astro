<section class="moin-entry">
  <h1 class="moin-title">Moin</h1>

  <div class="moin-meta">
    <span class="moin-pronunciation">/mɔyn/</span>
    <span class="tag tag-dark">INTERJECTION</span>
    <span class="tag tag-accent">Low German</span>
  </div>

  <ol class="moin-list">
    <li>
      <div class="moin-row">
        <span class="moin-index">1.</span>
        <div>
          <p class="moin-definition">
            Greeting used throughout the day in northern Germany — morning, noon, and night.
          </p>
          <p class="moin-example">“Moin! How's your day going?”</p>
        </div>
      </div>
    </li>
    <li>
      <div class="moin-row">
        <span class="moin-index">2.</span>
        <div>
          <p class="moin-definition">
            A word that stuck — moved from Bremen, kept the greeting.
          </p>
          <p class="moin-example">“Moin everyone, let's get started.”</p>
        </div>
      </div>
    </li>
  </ol>
</section>

